/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    DeepInvirus Nextflow config file
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
*/

import java.time.LocalDateTime
import java.time.format.DateTimeFormatter

def run_timestamp = LocalDateTime.now().format(DateTimeFormatter.ofPattern("yyyyMMdd_HHmmss"))

// -----------------------------------------------------------------------
// Default parameters
// -----------------------------------------------------------------------
params {
    // Input / Output
    reads      = null
    host       = 'human'
    outdir     = "./${run_timestamp}_deepinvirus_results"

    // Analysis options
    trimmer    = 'bbduk'
    assembler  = 'megahit'
    search     = 'very-sensitive'
    skip_ml    = false
    db_dir     = null         // DB root directory. All sub-DBs auto-detected by folder name.
                               // Example: --db_dir ~/Database/DeepInvirus
                               // Override individual DBs with --kraken2_db, --uniref50_db, etc.

    // Tool-specific arguments
    fastp_args = ''
    min_contig_len = 500       // Minimum contig length for assembly
    min_virus_score = 0.7      // Minimum geNomad virus score
    min_bitscore = 50          // Minimum Diamond bitscore
    checkv_db = null           // Path to CheckV database (optional, null = skip CheckV)
    exclusion_db = null        // Path to SwissProt Diamond DB for non-viral contig exclusion (optional)
    kraken2_db = null          // Path to Kraken2 DB directory (optional, null = skip Kraken2)
    uniref50_db = null         // Path to UniRef50 Diamond DB for Tier 2 verification (optional)
    viral_nt_db = null         // Path prefix to viral nucleotide BLAST DB for Tier 3 (optional)
    polymicrobial_nt_db = null // Path prefix to polymicrobial BLAST DB for Tier 4 (optional)
    kraken2_confidence = 0.0   // Kraken2 confidence threshold; keep 0.0 to annotate everything
    bracken_read_len   = 150  // Bracken read length (must match DB build k-mer distribution)
    bracken_level      = 'S'  // Bracken taxonomy level: S=species, G=genus, F=family
    bracken_threshold  = 0    // Bracken minimum read threshold for reporting

    // Max resource limits (adjust for your server)
    // Default: 32 cores / 256 GB — override with --max_cpus 16 --max_memory '64.GB'
    max_cpus   = 32
    max_memory = '256.GB'
    max_time   = '24.h'

    // Work directory options
    // RAM disk support for I/O-intensive pipelines
    use_ramdisk = false                         // Use /dev/shm as work directory
    ramdisk_path = '/dev/shm/deepinvirus_work'  // RAM disk mount point
    ramdisk_size = 0                            // RAM disk size in GB (0=auto)
    work_dir = null                             // Custom work dir (null = default ./work)

    // Help
    help       = false
}

// -----------------------------------------------------------------------
// Load base config (resource labels)
// -----------------------------------------------------------------------
includeConfig 'conf/base.config'

// -----------------------------------------------------------------------
// Profiles
// -----------------------------------------------------------------------
profiles {
    docker {
        includeConfig 'conf/docker.config'
        singularity.enabled    = false
    }
    singularity {
        includeConfig 'conf/singularity.config'
        docker.enabled         = false
    }
    test {
        includeConfig 'conf/test.config'
    }
}

// -----------------------------------------------------------------------
// Default process settings
// -----------------------------------------------------------------------
process {
    errorStrategy = 'retry'
    maxRetries    = 2
}

// -----------------------------------------------------------------------
// Execution reports
// -----------------------------------------------------------------------
def trace_timestamp = new java.util.Date().format('yyyy-MM-dd_HH-mm-ss')

timeline {
    enabled   = true
    overwrite = true
    file      = "${params.outdir}/pipeline_info/timeline_${trace_timestamp}.html"
}
report {
    enabled   = true
    overwrite = true
    file      = "${params.outdir}/pipeline_info/report_${trace_timestamp}.html"
}
trace {
    enabled   = true
    overwrite = true
    file      = "${params.outdir}/pipeline_info/trace_${trace_timestamp}.txt"
    fields    = 'task_id,hash,native_id,process,tag,name,status,exit,module,container,cpus,time,disk,memory,attempt,submit,start,complete,duration,realtime,queue,%cpu,%mem,rss,vmem,peak_rss,peak_vmem,rchar,wchar,syscr,syscw,read_bytes,write_bytes,vol_ctxt,inv_ctxt,env,workdir,scratch,error_action'
}
dag {
    enabled   = true
    overwrite = true
    file      = "${params.outdir}/pipeline_info/dag_${trace_timestamp}.html"
}

// -----------------------------------------------------------------------
// Manifest
// -----------------------------------------------------------------------
manifest {
    name            = 'DeepInvirus'
    author          = 'DeepInvirus Team'
    homePage        = ''
    description     = 'Viral metagenomics pipeline: Raw FASTQ to publication-ready results'
    mainScript      = 'main.nf'
    nextflowVersion = '!>=23.04.0'
    version         = '0.3.0'
}
