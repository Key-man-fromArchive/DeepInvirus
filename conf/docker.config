/*
 * @TASK T0.2 - Docker container configuration
 * @SPEC docs/planning/02-trd.md#2.2-분석-도구
 *
 * Process label -> container mapping for DeepInvirus pipeline.
 * Image naming convention: deepinvirus/{module}:{version}
 * Reference: docs/planning/07-coding-convention.md#3.3-Docker
 */

docker {
    enabled = true
    runOptions = '-u $(id -u):$(id -g) -e MPLCONFIGDIR=/tmp/matplotlib -e HOME=/tmp'
}

process {

    // --- QC Module ---
    // fastp (>=0.23) + minimap2 (>=2.26) + samtools (>=1.18)
    withLabel: 'process_fastp' {
        container = 'deepinvirus/qc:1.0.0'
    }
    withLabel: 'process_host_removal' {
        container = 'deepinvirus/qc:1.0.0'
    }

    // --- Assembly Module ---
    // MEGAHIT (>=1.2.9) + metaSPAdes (>=3.15)
    withLabel: 'process_megahit' {
        container = 'deepinvirus/assembly:1.0.0'
    }
    withLabel: 'process_metaspades' {
        container = 'deepinvirus/assembly:1.0.0'
    }

    // --- Detection Module ---
    // geNomad (>=1.7) + Diamond (>=2.1)
    withLabel: 'process_genomad' {
        container = 'deepinvirus/detect:1.0.0'
    }
    withLabel: 'process_diamond' {
        container = 'deepinvirus/detect:1.0.0'
    }

    // --- Classification Module ---
    // MMseqs2 (>=15.6) + TaxonKit (>=0.15) + CoverM (>=0.7)
    withLabel: 'process_mmseqs' {
        container = 'deepinvirus/classify:1.0.0'
    }
    withLabel: 'process_taxonkit' {
        container = 'deepinvirus/classify:1.0.0'
    }
    withLabel: 'process_coverm' {
        container = 'deepinvirus/classify:1.0.0'
    }

    // --- Reporting Module ---
    // Python 3.11 + visualization/report libraries
    withLabel: 'process_diversity' {
        container = 'deepinvirus/reporting:1.0.0'
    }
    withLabel: 'process_merge' {
        container = 'deepinvirus/reporting:1.0.0'
    }
    withLabel: 'process_dashboard' {
        container = 'deepinvirus/reporting:1.0.0'
    }
    withLabel: 'process_report' {
        container = 'deepinvirus/reporting:1.0.0'
    }
    withLabel: 'process_multiqc' {
        container = 'deepinvirus/reporting:1.0.0'
    }

}
