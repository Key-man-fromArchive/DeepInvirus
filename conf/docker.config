/*
 * Docker container configuration for DeepInvirus pipeline.
 * Each process label maps to a container image with explicit resource limits.
 * Image naming convention: deepinvirus/{module}:{version}
 */

docker {
    enabled = true
    runOptions = '-u $(id -u):$(id -g) -e MPLCONFIGDIR=/tmp/matplotlib -e HOME=/tmp -v /mnt:/mnt:ro'
}

process {

    // --- QC Module ---
    withLabel: 'process_bbduk' {
        container = 'deepinvirus/qc:1.0.0'
        cpus = 32
        memory = '32 GB'
        time = '24h'
    }
    withLabel: 'process_fastp' {
        container = 'deepinvirus/qc:1.0.0'
        cpus = 16
        memory = '32 GB'
        time = '24h'
    }
    withLabel: 'process_fastqc' {
        container = 'deepinvirus/qc:1.0.0'
        cpus = 4
        memory = '8 GB'
        time = '24h'
    }
    withLabel: 'process_host_removal' {
        container = 'deepinvirus/qc:1.0.0'
        cpus = 32
        memory = '128 GB'
        time = '24h'
    }

    // --- Assembly Module ---
    withLabel: 'process_megahit' {
        container = 'deepinvirus/assembly:1.0.0'
        cpus = 32
        memory = '128 GB'
        time = '24h'
    }
    withLabel: 'process_metaspades' {
        container = 'deepinvirus/assembly:1.0.0'
        cpus = 32
        memory = '256 GB'
        time = '24h'
    }

    // --- Detection Module ---
    withLabel: 'process_genomad' {
        container = 'deepinvirus/detect:1.0.0'
        cpus = 32
        memory = '128 GB'
        time = '24h'
    }
    withLabel: 'process_diamond' {
        container = 'deepinvirus/detect:1.0.0'
        cpus = 32
        memory = '128 GB'
        time = '24h'
    }

    // --- Classification Module ---
    withLabel: 'process_mmseqs' {
        container = 'deepinvirus/classify:1.0.0'
        cpus = 32
        memory = '128 GB'
        time = '24h'
    }
    withLabel: 'process_taxonkit' {
        container = 'deepinvirus/classify:1.0.0'
        cpus = 4
        memory = '8 GB'
        time = '24h'
    }
    withLabel: 'process_coverm' {
        container = 'deepinvirus/classify:1.0.0'
        cpus = 16
        memory = '64 GB'
        time = '24h'
    }

    // --- Reporting Module ---
    withLabel: 'process_merge' {
        container = 'deepinvirus/reporting:1.0.0'
        cpus = 4
        memory = '16 GB'
        time = '24h'
    }
    withLabel: 'process_diversity' {
        container = 'deepinvirus/reporting:1.0.0'
        cpus = 4
        memory = '16 GB'
        time = '24h'
    }
    withLabel: 'process_dashboard' {
        container = 'deepinvirus/reporting:1.0.0'
        cpus = 4
        memory = '16 GB'
        time = '24h'
    }
    withLabel: 'process_report' {
        container = 'deepinvirus/reporting:1.0.0'
        cpus = 4
        memory = '16 GB'
        time = '24h'
    }
    withLabel: 'process_multiqc' {
        container = 'deepinvirus/reporting:1.0.0'
        cpus = 4
        memory = '8 GB'
        time = '24h'
    }
    withLabel: 'process_prodigal' {
        container = 'deepinvirus/reporting:1.0.0'
        cpus = 4
        memory = '8 GB'
        time = '24h'
    }
}
