/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    DeepInvirus test config
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Minimal resource settings for CI/CD and local testing.
    Uses small test datasets located in tests/data/.
*/

params {
    // Test input data
    reads      = "${projectDir}/tests/data/reads/*_R{1,2}.fastq.gz"
    host       = 'none'
    outdir     = './results_test'
    assembler  = 'megahit'
    search     = 'fast'
    skip_ml    = false
    db_dir     = null

    // Minimal resources for test
    max_cpus   = 2
    max_memory = '4.GB'
    max_time   = '30.m'
}
