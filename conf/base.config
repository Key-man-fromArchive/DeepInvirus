// @TASK T0.1 - 기본 리소스 설정
// @SPEC docs/planning/07-coding-convention.md#4.2-리소스-라벨

/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    DeepInvirus base config - process resource labels
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Default: 32 cores / 256 GB RAM
    Adjust via: --max_cpus 16 --max_memory '64.GB'
*/

process {

    // Default (for unlabeled processes)
    cpus   = { check_max( 4,    'cpus'   ) }
    memory = { check_max( 8.GB, 'memory' ) }
    time   = { check_max( 1.h,  'time'   ) }

    // -----------------------------------------------------------------------
    // Resource labels - scaled to fraction of total resources
    // Adjust total via params.max_cpus / params.max_memory
    // -----------------------------------------------------------------------

    withLabel: process_low {
        cpus   = { check_max( Math.max(2, (params.max_cpus as int) / 8),        'cpus'   ) }
        memory = { check_max( "${Math.max(4, (params.max_memory.toGiga()) / 32)}GB", 'memory' ) }
        time   = { check_max( 2.h,   'time'   ) }
    }

    withLabel: process_medium {
        cpus   = { check_max( Math.max(4, (params.max_cpus as int) / 2),        'cpus'   ) }
        memory = { check_max( "${Math.max(8, (params.max_memory.toGiga()) / 4)}GB",  'memory' ) }
        time   = { check_max( 8.h,   'time'   ) }
    }

    withLabel: process_high {
        cpus   = { check_max( params.max_cpus as int,                            'cpus'   ) }
        memory = { check_max( "${Math.max(16, (params.max_memory.toGiga()) / 2)}GB", 'memory' ) }
        time   = { check_max( 16.h,  'time'   ) }
    }

    withLabel: process_high_memory {
        cpus   = { check_max( params.max_cpus as int,                            'cpus'   ) }
        memory = { check_max( params.max_memory,                                 'memory' ) }
        time   = { check_max( 24.h,  'time'   ) }
    }
}

// -----------------------------------------------------------------------
// Function to ensure resources do not exceed maximum limits
// -----------------------------------------------------------------------
def check_max(obj, type) {
    if (type == 'memory') {
        try {
            if (obj.compareTo(params.max_memory as nextflow.util.MemoryUnit) == 1)
                return params.max_memory as nextflow.util.MemoryUnit
            else
                return obj
        } catch (all) {
            println "WARNING: Max memory '${params.max_memory}' is not valid. Using default: $obj"
            return obj
        }
    } else if (type == 'time') {
        try {
            if (obj.compareTo(params.max_time as nextflow.util.Duration) == 1)
                return params.max_time as nextflow.util.Duration
            else
                return obj
        } catch (all) {
            println "WARNING: Max time '${params.max_time}' is not valid. Using default: $obj"
            return obj
        }
    } else if (type == 'cpus') {
        try {
            return Math.min( obj as int, params.max_cpus as int )
        } catch (all) {
            println "WARNING: Max cpus '${params.max_cpus}' is not valid. Using default: $obj"
            return obj
        }
    }
}
