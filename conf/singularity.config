/*
 * @TASK T0.2 - Singularity container configuration
 * @SPEC docs/planning/02-trd.md#2.1-파이프라인-프레임워크
 *
 * Singularity settings for HPC environments.
 * Automatically pulls Docker images and converts to SIF format.
 * Reference: docs/planning/07-coding-convention.md#3.3-Docker
 */

singularity {
    enabled = true
    autoMounts = true
    cacheDir = "${params.singularity_cache_dir ?: "${HOME}/.singularity/cache"}"
}

process {

    // --- QC Module ---
    withLabel: 'process_fastp' {
        container = 'docker://deepinvirus/qc:1.0.0'
    }
    withLabel: 'process_host_removal' {
        container = 'docker://deepinvirus/qc:1.0.0'
    }

    // --- Assembly Module ---
    withLabel: 'process_megahit' {
        container = 'docker://deepinvirus/assembly:1.0.0'
    }
    withLabel: 'process_metaspades' {
        container = 'docker://deepinvirus/assembly:1.0.0'
    }

    // --- Detection Module ---
    withLabel: 'process_genomad' {
        container = 'docker://deepinvirus/detect:1.0.0'
    }
    withLabel: 'process_diamond' {
        container = 'docker://deepinvirus/detect:1.0.0'
    }

    // --- Classification Module ---
    withLabel: 'process_mmseqs' {
        container = 'docker://deepinvirus/classify:1.0.0'
    }
    withLabel: 'process_taxonkit' {
        container = 'docker://deepinvirus/classify:1.0.0'
    }
    withLabel: 'process_coverm' {
        container = 'docker://deepinvirus/classify:1.0.0'
    }

    // --- Reporting Module ---
    withLabel: 'process_diversity' {
        container = 'docker://deepinvirus/reporting:1.0.0'
    }
    withLabel: 'process_merge' {
        container = 'docker://deepinvirus/reporting:1.0.0'
    }
    withLabel: 'process_dashboard' {
        container = 'docker://deepinvirus/reporting:1.0.0'
    }
    withLabel: 'process_report' {
        container = 'docker://deepinvirus/reporting:1.0.0'
    }

}
